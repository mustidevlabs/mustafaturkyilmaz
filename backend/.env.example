HOST=0.0.0.0
PORT=1337
# SQLite (path is relative to `backend/` when you run npm from that folder). Do not set DATABASE_FILENAME to an empty value.
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified
# Optional: invite-only POST /api/admin-auth/register (custom route). admin-web no longer uses sign-up; omit unless you call that API.
# ADMIN_WEB_INVITE_SECRET=
