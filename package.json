{
  "name": "mustafaturkyilmaz-portfolio",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo: Strapi CMS (backend) + Next.js (frontend)",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm run develop --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix backend && npm run build --prefix frontend",
    "start": "concurrently -n backend,frontend -c blue,magenta \"npm:start:backend\" \"npm:start:frontend\"",
    "start:backend": "npm run start --prefix backend",
    "start:frontend": "npm run start --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
