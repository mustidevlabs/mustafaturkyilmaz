# --- Admin gate (Strapi Users & Permissions) ---
# Create application users in Strapi Admin; admin-web is login-only.
# Local dev only: skip auth when NODE_ENV=development (never set in production).
# SKIP_ADMIN_AUTH=1

NEXT_PUBLIC_STRAPI_URL=https://timely-spirit-9e046731e1.strapiapp.com
# Strapi Cloud (same project as `backend/` workspace). Change URL for local Strapi.
# Public portfolio link in header; default matches portfolio-web dev port.
NEXT_PUBLIC_PORTFOLIO_URL=http://localhost:3000
# Strapi API token: find + update + delete on Ledgeria Issue (full access is simplest).
STRAPI_API_TOKEN=
# Development only: if Node TLS to Strapi fails, reuse STRAPI_API_TOKEN for browser fetch (no duplicate line). Never set in production.
# STRAPI_DEV_MIRROR_API_TOKEN_TO_BROWSER=1
# Dev only: alternative to mirroring — duplicate token here for browser fetch (inlined in client JS).
# NEXT_PUBLIC_STRAPI_DEV_BROWSER_TOKEN=
# Optional: corporate outbound proxy (same semantics as curl / Git). NO_PROXY is respected.
# HTTPS_PROXY=http://127.0.0.1:8888
# NO_PROXY=localhost,127.0.0.1
# Optional: PEM file with extra CAs when a proxy does TLS inspection (see Node docs).
# NODE_EXTRA_CA_CERTS=/path/to/org-root.pem
